{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "@temporal-contract/typedoc",
    "typedoc-plugin-markdown",
    "@changesets/config"
  ],
  "workspaces": {
    ".": {
      "entry": ["lefthook.yml"]
    },
    "packages/*": {
      "project": ["src/**/*.ts"]
    },
    "packages/client": {
      "entry": ["src/__tests__/test.workflows.ts"]
    },
    "packages/worker": {
      "entry": ["src/__tests__/test.workflows.ts"]
    },
    "examples/order-processing-worker": {
      "entry": ["src/application/workflows.ts"]
    },
    "tools/tsconfig": {
      "entry": ["*.json"]
    },
    "tools/typedoc": {
      "entry": ["*.json"],
      "ignoreDependencies": ["typedoc", "typedoc-plugin-markdown"]
    },
    "docs": {
      "ignoreDependencies": ["@temporal-contract/tsconfig"]
    }
  },
  "ignore": []
}
