{
  "name": "@temporal-contract/testing",
  "version": "2.1.0",
  "description": "Temporal testing utilities",
  "homepage": "https://github.com/btravers/temporal-contract#readme",
  "bugs": {
    "url": "https://github.com/btravers/temporal-contract/issues"
  },
  "license": "MIT",
  "author": "Benoit TRAVERS <benoit.travers.fr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/btravers/temporal-contract.git",
    "directory": "packages/testing"
  },
  "files": [
    "config",
    "dist"
  ],
  "type": "module",
  "exports": {
    "./extension": {
      "types": "./dist/extension.d.mts",
      "import": "./dist/extension.mjs"
    },
    "./global-setup": {
      "types": "./dist/global-setup.d.mts",
      "import": "./dist/global-setup.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/global-setup.ts src/extension.ts --format esm --dts --clean",
    "build:docs": "typedoc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@temporalio/client": "catalog:",
    "@temporalio/worker": "catalog:",
    "testcontainers": "catalog:"
  },
  "devDependencies": {
    "@temporal-contract/tsconfig": "workspace:*",
    "@temporal-contract/typedoc": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typedoc": "catalog:",
    "typedoc-plugin-markdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "vitest": "^4"
  }
}
