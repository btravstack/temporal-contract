{
  "name": "@temporal-contract/client",
  "version": "2.4.0",
  "description": "Client utilities with unthrown Result/AsyncResult for consuming temporal-contract workflows",
  "keywords": [
    "client",
    "contract",
    "result",
    "temporal",
    "typescript",
    "unthrown"
  ],
  "homepage": "https://github.com/btravstack/temporal-contract#readme",
  "bugs": {
    "url": "https://github.com/btravstack/temporal-contract/issues"
  },
  "license": "MIT",
  "author": "Benoit TRAVERS <benoit.travers.fr@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/btravstack/temporal-contract.git",
    "directory": "packages/client"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts --clean",
    "build:docs": "typedoc",
    "dev": "tsdown src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest --project unit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "catalog:",
    "@temporal-contract/contract": "workspace:*"
  },
  "devDependencies": {
    "@temporal-contract/testing": "workspace:*",
    "@temporal-contract/tsconfig": "workspace:*",
    "@temporal-contract/typedoc": "workspace:*",
    "@temporalio/client": "catalog:",
    "@temporalio/common": "catalog:",
    "@temporalio/worker": "catalog:",
    "@temporalio/workflow": "catalog:",
    "@types/node": "catalog:",
    "@unthrown/vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "tsdown": "catalog:",
    "typedoc": "catalog:",
    "typedoc-plugin-markdown": "catalog:",
    "typescript": "catalog:",
    "unthrown": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@temporalio/client": "^1",
    "@temporalio/common": "^1",
    "unthrown": "^0.1"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
